{
  "schema_version": 1,
  "app": {
    "name": "Liquidity Sniper",
    "version": "2.0.0",
    "strategy_version": "1.0.0",
    "tagline": "Precision liquidity sweep scanner for HTF/LTF execution."
  },
  "scanner": {
    "symbols": [
      "EURUSD",
      "GBPUSD",
      "USDJPY",
      "EURJPY",
      "GBPJPY",
      "AUDUSD",
      "NZDUSD",
      "USDCAD",
      "USDCHF",
      "XAUUSD",
      "BTCUSD",
      "ETHUSD"
    ],
    "symbol_aliases": {},
    "htf_timeframes": [
      "M15",
      "M30",
      "H1",
      "H4"
    ],
    "ltf_timeframes": [
      "M3",
      "M5",
      "M15",
      "H1"
    ],
    "confirmation_limit": 2,
    "loop_interval_sec": 60,
    "ob_fvg_mode": "medium",
    "strict_ifvg": true,
    "entry_model": "ifvg_first_edge",
    "sl_model": "origin_candle_extreme",
    "alert_mode": "both",
    "cooldown_sec": 1800
  },
  "telegram": {
    "enabled": true,
    "bot_token": "",
    "chat_id": ""
  },
  "storage": {
    "state_backend": "json",
    "history_backend": "sqlite"
  }
}
